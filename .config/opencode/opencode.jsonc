{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true,
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      },
      "playwright": {
        "type": "local",
        "command": ["npx", "@playwright/mcp@latest"],
        "enabled": true
      },
      "supabase": {
        "type": "remote",
        "url": "https://mcp.supabase.com/mcp",
        "enabled": true
      }
    }
  }
}
